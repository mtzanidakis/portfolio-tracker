# --- Production (tsrp reverse proxy) ---
HOSTNAME=portfolio
TS_AUTHKEY=XXXX

# --- Shared ---
# Optional CoinGecko Demo API key for a dedicated rate-limit quota.
# Without it, the free public endpoint is used.
# PT_COINGECKO_API_KEY=

# Browser session lifetime. Accepts Go duration syntax (e.g. "720h") or
# an integer-days shorthand ("30d").
# PT_SESSION_LIFETIME=30d

# Timezone for the server container (used for log timestamps).
TZ=Europe/Athens

# Version tag for local dev builds.
VERSION=dev
